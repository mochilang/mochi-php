// Phase 10.2: subscribe_limit drops messages once the subscriber's
// queue reaches the configured limit. The PHP runtime is synchronous
// (emit fans out into the subscriber's buffer in the same call), so
// no sleep is needed. After draining the buffer, a subsequent emit
// passes through again.
let s: stream<int> = make_stream(8)
let sub = subscribe_limit(s, 2)
emit(s, 1)
emit(s, 2)
emit(s, 3)
emit(s, 4)
emit(s, 5)
let a = recv_sub(sub)
let b = recv_sub(sub)
print(a)
print(b)
emit(s, 99)
let c = recv_sub(sub)
print(c)
